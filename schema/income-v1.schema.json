{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stock-financials.local/src/stock-financials/schema/income-v1.schema.json",
  "title": "IncomeStatementV1",
  "type": "object",
  "required": [
    "schemaVersion",
    "statementType",
    "ticker",
    "quarters",
    "rows",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "statementType": { "const": "income" },
    "ticker": { "type": "string", "pattern": "^[A-Z0-9.-]+$" },
    "companyName": { "type": "string" },
    "currency": { "type": "string", "default": "USD" },
    "unit": { "type": "string", "enum": ["millions", "thousands"] },
    "fiscalYearEndMonth": { "type": "integer", "minimum": 1, "maximum": 12 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "edgar": {
      "type": "object",
      "properties": {
        "cik": { "type": "string" },
        "latestQuarterlyFilingDate": { "type": "string", "format": "date" },
        "latestQuarterlyForm": { "type": "string" },
        "latestQuarterlyAccession": { "type": "string" },
        "latestQuarterlyUrl": { "type": "string", "format": "uri" }
      }
    },
    "quarters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "periodEnd"],
        "properties": {
          "label": { "type": "string" },
          "periodEnd": { "type": "string", "format": "date" },
          "fiscalLabel": { "type": "string" },
          "source": {
            "type": "object",
            "properties": {
              "form": { "type": "string" },
              "filingDate": { "type": "string", "format": "date" },
              "accessionNumber": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "values"],
        "properties": {
          "label": { "type": "string" },
          "values": {
            "type": "array",
            "items": { "type": "string" }
          },
          "kind": { "type": "string", "enum": ["normal", "italic", "total"] },
          "unit": { "type": "string", "enum": ["$", "%", "eps", "sh"] },
          "plottable": { "type": "boolean" },
          "derived": { "type": "boolean" }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "subtitle": { "type": "string" },
        "fiscalMapping": { "type": "string" },
        "stats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "tone": { "type": "string", "enum": ["info", "success", "danger", "warning"] }
            }
          }
        },
        "defaultChartRows": { "type": "array", "items": { "type": "string" } }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } },
    "verification": {
      "type": "object",
      "properties": {
        "grossProfitTies": { "type": "boolean" },
        "operatingProfitTies": { "type": "boolean" },
        "pretaxMinusTaxTiesNetIncome": { "type": "boolean" },
        "exceptions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
